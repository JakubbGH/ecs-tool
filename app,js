// 1. FALLBACK DATA: If the JSON fails to load, the app still works.
let database = [
    { "building": "TEST-B1", "ecs_list": ["ECS-TEST-01", "ECS-TEST-02"] }
];

document.addEventListener("DOMContentLoaded", () => {
    console.log("App Initialized. Fetching database...");
    loadData();
});

async function loadData() {
    try {
        // 2. USE A TIMESTAMP: This forces GitHub to give you the NEWEST version (prevents caching)
        const response = await fetch(`./database.json?v=${new Date().getTime()}`);
        
        if (!response.ok) {
            console.warn("database.json not found, using fallback data.");
            renderBuildingDropdown();
            return;
        }

        const data = await response.json();
        console.log("JSON Data Loaded Successfully:", data);

        if (data && data.length > 0) {
            database = data;
            renderBuildingDropdown();
        }
    } catch (error) {
        console.error("Critical Fetch Error:", error);
        renderBuildingDropdown(); // Still render fallback so the UI isn't broken
    }
}

function renderBuildingDropdown() {
    const bSelect = document.getElementById("buildingSelect");
    if (!bSelect) return console.error("Could not find buildingSelect in HTML");

    bSelect.innerHTML = ""; // Clear "Loading..." or old options
    
    database.forEach(item => {
        let opt = new Option(item.building, item.building);
        bSelect.add(opt);
    });

    console.log("Building dropdown populated.");
    updateEcsDropdown();
}

function updateEcsDropdown() {
    const bValue = document.getElementById("buildingSelect").value;
    const eSelect = document.getElementById("ecsSelect");
    const match = database.find(d => d.building === bValue);
    
    eSelect.innerHTML = ""; 
    if (match && match.ecs_list) {
        match.ecs_list.forEach(ecs => {
            eSelect.add(new Option(ecs, ecs));
        });
        console.log(`ECS dropdown updated for ${bValue}`);
    }
}

// --- ADD ROW & EXCEL LOGIC ---
function addRow() {
    const b = document.getElementById("buildingSelect").value;
    const e = document.getElementById("ecsSelect").value;
    const tbody = document.querySelector("#ecsTable tbody");
    
    const row = tbody.insertRow();
    row.innerHTML = `
        <td>${b}</td>
        <td>${e}</td>
        <td>
            <select style="padding:10px; width:100%;">
                <option>1HAND_POS</option>
                <option>2PREP_ALMT</option>
                <option>3WELDING</option>
                <option>4PUNCH</option>
            </select>
        </td>
        <td>
            <button onclick="this.parentElement.parentElement.remove()" 
                    style="background:#dc3545; color:white; border:none; padding:10px; font-weight:bold; width:100%; border-radius:5px;">
                DEL
            </button>
        </td>
    `;
}

function exportExcel() {
    const rows = document.querySelectorAll("#ecsTable tbody tr");
    if(rows.length === 0) return alert("Add data first!");

    let exportData = Array.from(rows).map(tr => ({
        "Building": tr.cells[0].innerText,
        "ECS Code": tr.cells[1].innerText,
        "Validation": tr.cells[2].querySelector("select").value
    }));

    const ws = XLSX.utils.json_to_sheet(exportData);
    const wb = XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb, ws, "Collection");
    XLSX.writeFile(wb, "Field_Data.xlsx");
}
