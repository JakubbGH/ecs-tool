let buildingsData = [];

fetch("buildings.json")
.then(res => res.json())
.then(data => {

    buildingsData = data;

    let table = document.getElementById("preview");

    data.forEach(row => {

        let tr = table.insertRow();

        tr.insertCell(0).innerText = row.building;
        tr.insertCell(1).innerText = row.ecs;
        tr.insertCell(2).innerText = "";

    });

});

function exportExcel(){

    let validation = document.getElementById("validation").value;

    let output = buildingsData.map(r => ({
        Building: r.building,
        "ECS Code": r.ecs,
        Validation: validation
    }));

    let ws = XLSX.utils.json_to_sheet(output);
    let wb = XLSX.utils.book_new();

    XLSX.utils.book_append_sheet(wb, ws, "ECS");

    XLSX.writeFile(wb,"ecs_validation.xlsx");

}
